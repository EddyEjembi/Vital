# Modal vLLM endpoint (set after: modal deploy infra/vllm_serve.py)
VITAL_LLM_BASE_URL=https://your-workspace--vital-nemotron-serve.modal.run/v1
VITAL_MODEL_ID=nemotron3-nano-4B-BF16

DEMO_MODE=false

VITAL_SERVER_HOST=127.0.0.1
VITAL_SERVER_PORT=7860
VITAL_LAUNCH_IN_BROWSER=true

# Optional tuning
VITAL_MAX_TOKENS=4096
VITAL_CONTEXT_LIMIT=8192
VITAL_DAILY_SCHEDULE_MAX_TOKENS=4096
VITAL_TOOL_TEMPERATURE=0.6
VITAL_JSON_TEMPERATURE=0.4